<!DOCTYPE html>
<html>
<head>
<title>Blog Platform with Admin Panel</title>

<style>

body{
font-family: Arial, sans-serif;
max-width:900px;
margin:auto;
background:url("https://images.unsplash.com/photo-1507842217343-583bb7270b66") no-repeat center center/cover;
min-height:100vh;
color:#333;
}

/* Glass container */

body > *{
background:rgba(255,255,255,0.9);
padding:15px;
border-radius:10px;
margin-top:10px;
}

/* Inputs */

input, textarea, select{
width:100%;
padding:10px;
margin:6px 0;
border-radius:6px;
border:1px solid #ccc;
}

/* Buttons */

button{
padding:10px 15px;
margin:5px 0;
cursor:pointer;
border:none;
border-radius:6px;
background:#4CAF50;
color:white;
font-weight:bold;
transition:0.3s;
}

button:hover{
background:#2e7d32;
transform:scale(1.05);
}

/* Post Card */

.post{
background:white;
border-radius:10px;
padding:15px;
margin-top:15px;
box-shadow:0 3px 10px rgba(0,0,0,0.2);
}

.comment{
margin-left:20px;
font-size:14px;
background:#f5f5f5;
padding:5px;
border-radius:5px;
}

img{
max-width:100%;
margin-top:10px;
border-radius:8px;
}

/* Editor */

.editor button{
background:#2196F3;
margin-right:5px;
}

.editor button:hover{
background:#0b79d0;
}

h1{
text-align:center;
}

</style>

</head>

<body>

<h1>Blogging Platform</h1>

<h2>Admin Login</h2>

<input id="username" placeholder="Username">
<input id="password" type="password" placeholder="Password">

<button onclick="login()">Login</button>

<div id="adminPanel" style="display:none">

<h2>Create Post</h2>

<input id="title" placeholder="Post Title">

<select id="category">
<option value="Technology">Technology</option>
<option value="Education">Education</option>
<option value="Lifestyle">Lifestyle</option>
</select>

<input id="tags" placeholder="Tags (comma separated)">

<div class="editor">
<button onclick="formatText('bold')">Bold</button>
<button onclick="formatText('italic')">Italic</button>
<button onclick="formatText('underline')">Underline</button>
</div>

<div id="content" contenteditable="true" style="border:1px solid #ccc;padding:10px;min-height:100px;border-radius:6px">
Write blog content here...
</div>

<br>

<input type="file" id="imageUpload">

<button onclick="createPost()">Publish Post</button>

</div>

<hr>

<h2>Search</h2>

<input id="search" placeholder="Search title">
<button onclick="searchPost()">Search</button>

<select id="filterCategory" onchange="filterCategory()">
<option value="all">All Categories</option>
<option value="Technology">Technology</option>
<option value="Education">Education</option>
<option value="Lifestyle">Lifestyle</option>
</select>

<hr>

<h2>Blog Posts</h2>

<div id="posts"></div>

<script>

let posts = JSON.parse(localStorage.getItem("posts")) || []

function savePosts(){
localStorage.setItem("posts", JSON.stringify(posts))
}

/* ADMIN LOGIN */

function login(){

let user=document.getElementById("username").value
let pass=document.getElementById("password").value

if(user==="admin" && pass==="1234"){

alert("Admin Login Successful")

document.getElementById("adminPanel").style.display="block"

}else{

alert("Wrong username or password")

}

}

/* TEXT FORMAT */

function formatText(command){
document.execCommand(command,false,null)
}

/* CREATE POST */

function createPost(){

let title=document.getElementById("title").value
let content=document.getElementById("content").innerHTML
let category=document.getElementById("category").value
let tags=document.getElementById("tags").value.split(",")

let imageInput=document.getElementById("imageUpload")
let imageURL=""

if(imageInput.files[0]){
imageURL=URL.createObjectURL(imageInput.files[0])
}

let post={
id:Date.now(),
title:title,
content:content,
category:category,
tags:tags,
image:imageURL,
comments:[]
}

posts.push(post)

savePosts()

displayPosts()

}

/* DISPLAY POSTS */

function displayPosts(){

let container=document.getElementById("posts")

container.innerHTML=""

posts.forEach(post=>{

container.innerHTML+=`

<div class="post">

<h3>${post.title}</h3>

<p><b>Category:</b> ${post.category}</p>

<p><b>Tags:</b> ${post.tags.join(", ")}</p>

<div>${post.content}</div>

${post.image ? `<img src="${post.image}">` : ""}

<button onclick="deletePost(${post.id})">Delete</button>

<h4>Comments</h4>

<input id="name${post.id}" placeholder="Your name">

<input id="comment${post.id}" placeholder="Write comment">

<button onclick="addComment(${post.id})">Add Comment</button>

<div>

${post.comments.map(c=>`<p class="comment"><b>${c.name}:</b> ${c.text}</p>`).join("")}

</div>

</div>

`

})

}

/* DELETE POST */

function deletePost(id){

posts=posts.filter(p=>p.id!==id)

savePosts()

displayPosts()

}

/* ADD COMMENT */

function addComment(id){

let name=document.getElementById("name"+id).value
let text=document.getElementById("comment"+id).value

posts.forEach(post=>{

if(post.id===id){

post.comments.push({name:name,text:text})

}

})

savePosts()

displayPosts()

}

/* SEARCH */

function searchPost(){

let keyword=document.getElementById("search").value.toLowerCase()

let filtered=posts.filter(p=>p.title.toLowerCase().includes(keyword))

renderFiltered(filtered)

}

/* FILTER CATEGORY */

function filterCategory(){

let category=document.getElementById("filterCategory").value

if(category==="all"){
displayPosts()
return
}

let filtered=posts.filter(p=>p.category===category)

renderFiltered(filtered)

}

/* RENDER FILTERED POSTS */

function renderFiltered(list){

let container=document.getElementById("posts")

container.innerHTML=""

list.forEach(post=>{

container.innerHTML+=`

<div class="post">

<h3>${post.title}</h3>

<p><b>Category:</b> ${post.category}</p>

<div>${post.content}</div>

${post.image ? `<img src="${post.image}">` : ""}

</div>

`

})

}

displayPosts()

</script>

</body>
</html>
